#############################
#		MAIN SETTINGS		#
#############################

HYDRUS_TOKEN=REPLACE_WITH_HYDRUS_API_KEY		# Hydrus Client API key.
HYDRUS_HOST=http://127.0.0.1:45869 				# Usually this is the default local Hydrus address.
TAG_SERVICE=A.I. Tags							# Where tags should be written.

# JTP-3
JTP_3_THRESHOLD=0.70                    # 0.00 to 1.00. Higher = stricter tag selection. Lower = more tags, but also more noise.
JTP_3_MAX_TAGS=30                       # 0 disables the cap. 1 and up keeps only that many tags.
JTP_3_BATCH_SIZE=4                      # Mostly affects speed / VRAM
JTP_3_NAMESPACE=auto                    # auto = category-aware tags where possible, all= for plain tags
JTP_3_SKIP_EXISTING_NAMESPACES=         # Optional: artist,character,copyright,rating... Skip those categories if that namespace already exists in TAG_SERVICE.

# Z3D-E621-Convnext
Z3D_E621_CONVNEXT_THRESHOLD=0.35
Z3D_E621_CONVNEXT_MAX_TAGS=30
Z3D_E621_CONVNEXT_BATCH_SIZE=8
Z3D_E621_CONVNEXT_NAMESPACE=auto
Z3D_E621_CONVNEXT_SKIP_EXISTING_NAMESPACES=

# wd-eva02-large-tagger-v3
WD_EVA02_LARGE_THRESHOLD=0.35
WD_EVA02_LARGE_MAX_TAGS=30
WD_EVA02_LARGE_BATCH_SIZE=8
WD_EVA02_LARGE_NAMESPACE=auto
WD_EVA02_LARGE_SKIP_EXISTING_NAMESPACES=

# camie-tagger
CAMIE_TAGGER_THRESHOLD=0.35
CAMIE_TAGGER_MAX_TAGS=30
CAMIE_TAGGER_BATCH_SIZE=8
CAMIE_TAGGER_NAMESPACE=auto
CAMIE_TAGGER_SKIP_EXISTING_NAMESPACES=

# Ratings-only launcher.
# Use WD_EVA02_LARGE or CAMIE_TAGGER. The other built-in models do not output ratings.
RATINGS_MODEL_KEY=CAMIE_TAGGER
RATINGS_BATCH_SIZE=8

HASH_FILE=hashes.txt							# Shared input file for regular tagging.

# Optional input files for the source-based launchers.
# Defaults to HASH_FILE if omitted.
# These can contain sha256/md5/sha1/sha512, file_id, or full https:// URLs.
SEARCH_ARTIST_FILE=hashes.txt
SEARCH_ALL_FILE=hashes.txt
SEARCH_YEAR_FILE=hashes.txt

TAGGER_VERBOSE=0						# 0 = quiet, 1 = print found data to the console.
HYDRUS_BATCH_INFERENCE=1				# 1 = batch inference, 0 = one image at a time.
AUTO_CHECK_UPDATES=1					# 1 = check GitHub Releases before each launcher starts, 0 = disable auto-check.
SEARCH_TIMEOUT=8						# Timeout for source-site requests.
SOURCE_LOOKUP_MAX_WORKERS=8				# Controls per-file source/url checks.
LOOKUP_RECORD_MAX_WORKERS=32			# Controls how many files search-all processes at once.

#############################
#		MISC / LOOKUP		#
#############################

# Required for reliable rule34.xxx source lookups.
# Get both values from your rule34.xxx account / API page.
RULE34_USER_ID=
RULE34_API_KEY=

# Recommended for authenticated gelbooru.com DAPI access.
GELBOORU_USER_ID=
GELBOORU_API_KEY=


# Automatic retry/backoff for source-site requests.
SOURCE_RETRY_MAX_ATTEMPTS=2
SOURCE_CIRCUIT_BREAKER_THRESHOLD=3
SOURCE_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
SOURCE_RETRY_BASE_DELAY_MS=750
SOURCE_RETRY_MAX_DELAY_MS=5000

SEARCH_DOUBLECHECK_FILE_SYSTEM=0		# If set to 1, Hydrus will try to double-check the file lookup again.

# Namespace names used by the source lookup helpers.
# Standard creator tag form is creator:name.
# For plain creator tags without "creator:" or "artist:", set SEARCH_ARTIST_NAMESPACE=none
SEARCH_ARTIST_NAMESPACE=creator
SEARCH_ALL_NAMESPACE=general=,copyright=copyright,character=character,meta=meta,species=species,lore=lore,rating=rating,year=year,site=source,filetype=filetype,artist=skip
SEARCH_YEAR_NAMESPACE=year

# Limit which source sites are checked during source-based lookup.
# Use all, or a comma-separated list from:
# danbooru, e621, e926, yandere, konachan, gelbooru, rule34, safebooru
SEARCH_ARTIST_SITES=all
SEARCH_ALL_SITES=all
SEARCH_YEAR_SITES=all

# SEARCH_ALL_NAMESPACE controls tags imported from source sites.
# Supported groups: general, character, series/copyright, meta, species, lore
# Supported extra fields: rating, year, site, filetype, artist
# The config key is artist, but creator is the recommended namespace value.
# Examples:
#   all=                  -> plain tags, no namespaces
#   all=source            -> source:tagname for every imported tag
#   general=,copyright=copyright,character=character,meta=meta,species=species,lore=lore,rating=rating,year=year,site=source,filetype=filetype,artist=skip
#   general=,meta=skip,year=skip,artist=creator

# Per-model namespace config for AI taggers.
# auto uses category-aware output when model metadata supports it:
#   general -> plain
#   character -> character:name
#   copyright/series -> copyright:name
#   artist -> creator:name
#   species -> species:name
#   meta -> meta:name
#   rating -> rating:name
#   year -> year:YYYY
# Examples:
#   auto
#   all=                  -> plain tags only
#   all=ai                -> ai:tag for every category
#   general=,character=character,artist=creator,meta=skip
